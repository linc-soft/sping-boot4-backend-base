# Copy this file to .env.local and fill real values. .env.local is gitignored.
# Used by VSCode launch.json (envFile) and IntelliJ IDEA Run Configurations (EnvFile plugin).

# Active Spring profile(s), e.g. dev / test / prod
SPRING_PROFILES_ACTIVE=dev

# ---- MySQL ----
DB_HOST=
DB_PORT=
DB_SCHEMA=
DB_USERNAME=
DB_PASSWORD=

# ---- Redis ----
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DATABASE=

# ---- Security ----
# JWT signing secret. Must be at least 32 characters long.
JWT_SECRET=
