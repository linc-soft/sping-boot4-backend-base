# Copy this file to .env.local and fill real values. .env.local is gitignored.
# Used by VSCode launch.json (envFile) and IntelliJ IDEA Run Configurations (EnvFile plugin).

# Active Spring profile(s), e.g. dev / test / prod
SPRING_PROFILES_ACTIVE=dev

# ---- MySQL ----
DB_HOST=
DB_PORT=
DB_SCHEMA=
DB_USERNAME=
DB_PASSWORD=

# ---- Redis ----
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DATABASE=

# ---- Mail (SMTP) ----
# Common configurations:
#   Gmail:      host=smtp.gmail.com, port=587, STARTTLS (default)
#   Outlook:    host=smtp.office365.com, port=587, STARTTLS (default)
#   QQ Mail:    host=smtp.qq.com, port=465, SSL → set MAIL_SSL_ENABLE=true, MAIL_STARTTLS_ENABLE=false
#   163 Mail:   host=smtp.163.com, port=465, SSL → set MAIL_SSL_ENABLE=true, MAIL_STARTTLS_ENABLE=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER_NAME=System Notification
MAIL_STARTTLS_ENABLE=true
MAIL_STARTTLS_REQUIRED=true
MAIL_SSL_ENABLE=false
MAIL_SSL_TRUST=*

# ---- Password Reset ----
PASSWORD_RESET_BASE_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_TTL_MINUTES=5

# ---- Security ----
# JWT signing secret. Must be at least 32 characters long.
JWT_SECRET=
