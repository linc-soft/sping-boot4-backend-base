<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback Configuration File

  Separate log files by type and configure rolling policy, compression, and automatic cleanup.
  Support differentiated configurations for multiple environments (dev/test/prod).

  Log File Classification:
    - app.log:       Main application log (all levels)
    - access.log:    Access log (HTTP requests/responses)
    - error.log:     Error log (ERROR level only)
    - operation.log: Operation log (business audit)

  All logs uniformly include traceId and username (obtained from MDC).
-->
<configuration>

  <!-- ========== Common Property Definition ========== -->
  <!-- Log file output directory -->
  <property name="LOG_HOME" value="logs"/>
  <!-- Unified log format (retrieve and output traceId and username from MDC) -->
  <property name="LOG_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId}] [%X{username}] %logger{36} - %msg%n"/>

  <!-- ========== Console output Appender (for development and test environments) ========== -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ========== Application main log Appender ========== -->
  <!-- Output all log levels to app.log -->
  <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_HOME}/app.log</file>
    <!-- Time and size-based rolling policy with automatic gzip compression -->
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_HOME}/archive/app.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <!-- Maximum size of a single file -->
      <maxFileSize>100MB</maxFileSize>
      <!-- Archive retention days -->
      <maxHistory>30</maxHistory>
      <!-- Maximum total archive size -->
      <totalSizeCap>5GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ========== Access log Appender ========== -->
  <!-- HTTP request/response access log to access.log -->
  <appender name="ACCESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_HOME}/access.log</file>
    <!-- Time and size-based rolling policy with automatic gzip compression -->
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_HOME}/archive/access.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <!-- Access log is large in volume, so set a larger single file size -->
      <maxFileSize>200MB</maxFileSize>
      <!-- Archive retention days -->
      <maxHistory>30</maxHistory>
      <!-- Maximum total archive size (access logs are large in size, set to 10GB) -->
      <totalSizeCap>10GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ========== Error log Appender ========== -->
  <!-- Output ERROR level logs only to error.log -->
  <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_HOME}/error.log</file>
    <!-- A filter that only accepts ERROR level logs and rejects all others. -->
    <filter class="ch.qos.logback.classic.filter.LevelFilter">
      <level>ERROR</level>
      <onMatch>ACCEPT</onMatch>
      <onMismatch>DENY</onMismatch>
    </filter>
    <!-- Time and size-based rolling policy with automatic gzip compression -->
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_HOME}/archive/error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <!-- Maximum size of a single file -->
      <maxFileSize>100MB</maxFileSize>
      <!-- Error log is long-term retention (90 days) -->
      <maxHistory>90</maxHistory>
      <!-- Maximum total archive size -->
      <totalSizeCap>5GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ========== Operation log Appender ========== -->
  <!-- Business audit operation log to operation.log -->
  <appender name="OPERATION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_HOME}/operation.log</file>
    <!-- Time and size-based rolling policy with automatic gzip compression -->
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_HOME}/archive/operation.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <!-- Maximum size of a single file -->
      <maxFileSize>100MB</maxFileSize>
      <!-- Error log is long-term retention (90 days) -->
      <maxHistory>90</maxHistory>
      <!-- Maximum total archive size -->
      <totalSizeCap>5GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ========== Logger Definition ========== -->

  <!-- Access log Logger -->
  <!-- Output logs from AccessLogInterceptor only to access.log, and do not propagate them to the ROOT logger (additivity=false). -->
  <logger name="com.lincsoft.interceptor.AccessLogInterceptor" level="INFO" additivity="false">
    <appender-ref ref="ACCESS_FILE"/>
  </logger>

  <!-- Operation log Logger -->
  <!-- Output logs from OperationLogAspect only to operation.log, and do not propagate them to the ROOT logger (additivity=false). -->
  <logger name="com.lincsoft.aspect.OperationLogAspect" level="INFO" additivity="false">
    <appender-ref ref="OPERATION_FILE"/>
  </logger>

  <!-- ========== Environment-specific Settings (springProfile) ========== -->

  <!-- Development environment: WARN level + console output + file output -->
  <springProfile name="dev">
    <root level="WARN">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="APP_FILE"/>
      <appender-ref ref="ERROR_FILE"/>
    </root>
  </springProfile>

  <!-- Test environment: INFO level + console output + file output -->
  <springProfile name="test">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="APP_FILE"/>
      <appender-ref ref="ERROR_FILE"/>
    </root>
  </springProfile>

  <!-- Production environment: INFO level + file output only (no console output, I/O overhead reduction) -->
  <springProfile name="prod">
    <root level="INFO">
      <appender-ref ref="APP_FILE"/>
      <appender-ref ref="ERROR_FILE"/>
    </root>
  </springProfile>

</configuration>
